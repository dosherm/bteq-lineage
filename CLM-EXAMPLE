/**************************************************************************************************
Join CSA LOAD LOG and EDW LOAD LOG Tables to get the latest EDW LOAD LOG KEY, which is 
required to be inserted into EDW Table.
**************************************************************************************************/


INNER JOIN      CSA_LOAD_LOG CLL
ON              CLL.LOAD_LOG_KEY         =  STG.LOAD_LOG_KEY
AND             CLL.PBLSH_IND            =  'Y' 
  
INNER JOIN      EDW_LOAD_LOG ELL
ON              CLL.EDW_LOAD_LOG_KEY     = ELL.LOAD_LOG_KEY
AND             ELL.PBLSH_IND            = 'N'
AND             ELL.SUBJ_AREA_NM         = '$CSA2EDW_CLM_SUBJ_AREA_NM'
AND             ELL.WORK_FLOW_NM         = '$CSA2EDW_CLM_WORK_FLOW_NM'
AND             ELL.LOAD_END_DTM         = '$CSA2EDW_CLM_HIGH_DATE_TIME'


/**************************************************************************************************
Join to identify the latest records BASED ON KEY COLUMNS 
**************************************************************************************************/

INNER JOIN WORK_CLM GTT
ON              STG.CLM_ADJSTMNT_KEY    = GTT.CLM_ADJSTMNT_KEY
AND             STG.TRNSCTN_CD          = 'I'


/*******************************************************************************
FINDING THE LATEST ROWS FROM THE CSA TABLE
*******************************************************************************/ 

QUALIFY ROW_NUMBER()  OVER( PARTITION BY STG.CLM_ADJSTMNT_KEY
                            ORDER     BY STG.TRNSCTN_DTM DESC )  = 1 
;

/************************************** Error Handling *******************************************/
.IF ERRORCODE <> 0 THEN .GOTO ERRORS
/************************************** Error Handling *******************************************/

/**************************************************************************************************
STEP 1.3 :IDENTIFY RECORDS FROM STG Table TO UPDATE IN THE EDW
***************************************************************************************************
Update rows in the CLM table from STG table.
**************************************************************************************************/

UPDATE $ETL_VIEWS_DB_LD.CLM

FROM    
        (
        
        SELECT 
                 CLM_ADJSTMNT_KEY
                ,ADJDCTN_DT             AS ADJDCTN_DT
                ,CLM_PRCS_DT            AS CLM_PRCS_DT
                ,CLM_ACTN_DT            AS CLM_ACTN_DT
                ,ELL.LOAD_LOG_KEY       AS UPDTD_LOAD_LOG_KEY
                /* below added for PV31831 for 9/16/16 rel */
                ,PROV_SRVC_AGRMNT_ID    AS PROV_SRVC_AGRMNT_ID
        FROM    CLM_STG STG
        
        /**************************************************************************************************
        Join CSA LOAD LOG and EDW LOAD LOG Tables to get the latest EDW LOAD LOG KEY, which is 
        required to be inserted into EDW Table.
        **************************************************************************************************/
        
        INNER JOIN      CSA_LOAD_LOG CLL
        ON              CLL.LOAD_LOG_KEY        =  STG.LOAD_LOG_KEY
        AND             CLL.PBLSH_IND           =  'Y' 
         
        INNER JOIN      EDW_LOAD_LOG ELL
        ON              CLL.EDW_LOAD_LOG_KEY    = ELL.LOAD_LOG_KEY
        AND             ELL.PBLSH_IND           = 'N'
        AND             ELL.SUBJ_AREA_NM        = '$CSA2EDW_CLM_SUBJ_AREA_NM'
        AND             ELL.WORK_FLOW_NM        = '$CSA2EDW_CLM_WORK_FLOW_NM'
        AND             ELL.LOAD_END_DTM        = '$CSA2EDW_CLM_HIGH_DATE_TIME' 

        WHERE STG.TRNSCTN_CD = 'U'
        
        QUALIFY ROW_NUMBER()  OVER( PARTITION BY STG.CLM_ADJSTMNT_KEY
                                        ORDER     BY STG.TRNSCTN_DTM DESC )  = 1
        ) CSTG
SET
         ADJDCTN_DT             = CSTG.ADJDCTN_DT
        ,CLM_ACTN_DT            = CSTG.CLM_ACTN_DT
        ,CLM_PRCS_DT            = CSTG.CLM_PRCS_DT
        ,UPDTD_LOAD_LOG_KEY     = CSTG.UPDTD_LOAD_LOG_KEY
        /* below added for PV31831 for 9/16/16 rel */
        ,PROV_SRVC_AGRMNT_ID    = CSTG.PROV_SRVC_AGRMNT_ID
WHERE   $ETL_VIEWS_DB_LD.CLM.CLM_ADJSTMNT_KEY    = CSTG.CLM_ADJSTMNT_KEY

;

/************************************** Error Handling *******************************************/
.IF ERRORCODE <> 0 THEN .GOTO ERRORS
