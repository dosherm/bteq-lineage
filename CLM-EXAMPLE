                AND             LOAD_END_DTM      = '$CSA2EDW_CLM_HIGH_DATE_TIME') 
				WHERE EDW_CLM.CLM_ADJSTMNT_KEY IS NULL
                GROUP BY STG.CLM_ADJSTMNT_KEY

        ) REC
) REC_CNT,

EDW_LOAD_LOG ELL, AUDT_BLNCG_RULE ABR

WHERE   ELL.SUBJ_AREA_NM        = '$CSA2EDW_CLM_SUBJ_AREA_NM' 
